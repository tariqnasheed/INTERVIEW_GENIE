# .env.example – Environment variables template for InterviewGenie
# Copy this file to .env and fill in your actual values.

# Flask secret key – generate one with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Groq API key (free tier) – sign up at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Optional: custom database path (defaults to sqlite:///instance/app.db)
# DATABASE_URL=sqlite:///instance/app.db